APP_NAME=SynapseOS
ENVIRONMENT=local
API_PREFIX=/api/v1
LOG_LEVEL=INFO
LOG_JSON=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# LLM provider. Use "mock" for local demos without secrets, or "openai" in production.
LLM_PROVIDER=mock
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.2
OPENAI_API_KEY=

# LangSmith observability.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=synapseos
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# State and storage.
REDIS_URL=redis://redis:6379/0
DATABASE_URL=postgresql+asyncpg://synapseos:synapseos@postgres:5432/synapseos
VECTOR_BACKEND=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=synapseos_knowledge
CHROMA_PERSIST_DIR=./.chroma
EMBEDDING_DIMENSIONS=384

# Human approval.
HUMAN_APPROVAL_REQUIRED_RISK_SCORE=0.72
MAX_AGENT_ITERATIONS=10
TASK_QUEUE_NAME=synapseos:tasks
